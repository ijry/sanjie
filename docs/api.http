Content-Type: application/json
X-User-ID: {{userId}}

{
  "targetFloorId": 2,
  "amount": 40
}

### Wishes
GET {{baseUrl}}/api/wishes
X-User-ID: {{userId}}

### Wish detail
GET {{baseUrl}}/api/wishes/1
X-User-ID: {{userId}}

### Route wish
POST {{baseUrl}}/api/wishes/1/route
Content-Type: application/json
X-User-ID: {{userId}}

{
  "assignedDeity": "财神",
  "note": "转财运组"
}

### Resolve wish
POST {{baseUrl}}/api/wishes/1/resolve
Content-Type: application/json
X-User-ID: {{userId}}

{
  "note": "建议先上班"
}

### Reject wish
POST {{baseUrl}}/api/wishes/1/reject
Content-Type: application/json
X-User-ID: {{userId}}

{
  "note": "违反许愿配额"
}

### Soup inventory
GET {{baseUrl}}/api/soup/inventory
X-User-ID: {{userId}}

### Adjust soup inventory
POST {{baseUrl}}/api/soup/inventory/1/adjust
Content-Type: application/json
X-User-ID: {{userId}}

{
  "delta": 10,
  "note": "补货"
}

### Soup records
GET {{baseUrl}}/api/soup/records
X-User-ID: {{userId}}

### Audit logs
GET {{baseUrl}}/api/audit-logs
X-User-ID: {{userId}}
